.idea/
.DS_Store

.config/op/
.config/gcloud/
.config/raycast/
.config/github-copilot
.config/jgit
.config/htop/
.config/packer/

.config/docker/buildx/
.config/docker/contexts/
.config/docker/.token_seed*
.config/docker/cli-plugins

# zed
.config/zed/

# private
.private
.ssh/config

# iterm2 - ignore everything except the main config file
.config/iterm2/*
!.config/iterm2/com.googlecode.iterm2.plist

# yarn
.config/yarn

# .local/bin - ignore large binaries and pipx-managed shims
.local/bin/cloud-sql-proxy
.local/bin/f2py
.local/bin/numpy-config

# codex
.config/codex

# claude-profiles: ~/.claude-profiles is a symlink into this repo, so Claude
# Code's runtime data (sessions, cache, plugins, history, projects, backups,
# .claude.json) lands here. Only track settings + the skills/statusline symlinks.
.claude-profiles/*/*
!.claude-profiles/*/settings.json
!.claude-profiles/*/skills
!.claude-profiles/*/statusline-command.sh