#!/usr/bin/env zsh
# cs - context-switch: single session, three mode windows, scoped worktree picker
#
# Windows: research | review | work (fixed, created on session startup)
# Worktrees: ~/worktrees/<project>/{research,review,<branch-slug>}
#
# Each command switches to its mode window and cd's the pane there.
# Worktrees are created lazily on first use.

set -euo pipefail

CS_WORKTREES="${CS_WORKTREES_DIR:-$HOME/worktrees}"
CS_PROJECTS="${CS_PROJECTS_DIR:-$HOME/projects}"
CS_SESSION="${CS_SESSION:-main}"

die() { printf 'cs: %s\n' "$*" >&2; exit 1; }

branch_slug() { printf '%s' "$1" | tr '/' '-' | tr -cd '[:alnum:]_.-'; }

# ── context detection ─────────────────────────────────────────────────────────

_git_toplevel() { git rev-parse --show-toplevel 2>/dev/null || true; }

ctx_project() {
    local toplevel
    toplevel=$(_git_toplevel)
    local check="${toplevel:-$PWD}"

    if [[ "$check" == "$CS_WORKTREES"/* ]]; then
        local rel="${check#"$CS_WORKTREES"/}"
        echo "${rel%%/*}"; return
    fi
    if [[ "$PWD" == "$CS_WORKTREES"/* ]]; then
        local rel="${PWD#"$CS_WORKTREES"/}"
        echo "${rel%%/*}"; return
    fi
    if [[ "$check" == "$CS_PROJECTS"/* ]]; then
        local rel="${check#"$CS_PROJECTS"/}"
        echo "${rel%%/*}"; return
    fi
    if [[ -n "$toplevel" ]]; then
        basename "$toplevel"; return
    fi
}

# ── tmux helpers ──────────────────────────────────────────────────────────────

_current_mode() {
    tmux display-message -p '#{@cs_name}' 2>/dev/null
}

_window_idx() {
    local cs_name="$1"
    tmux list-windows -t "$CS_SESSION" -F '#{window_index} #{@cs_name}' 2>/dev/null \
        | awk -v n="$cs_name" '$2 == n {print $1; exit}'
}

_switch_to_mode() {
    local mode="$1"
    local idx
    idx=$(_window_idx "$mode")
    [[ -n "$idx" ]] || die "window '$mode' not found — restart tmux session"
    if [[ -n "${TMUX:-}" ]]; then
        tmux select-window -t "$CS_SESSION:$idx"
    else
        tmux attach -t "$CS_SESSION:$idx"
    fi
}

_cd_pane() {
    local dir="$1"
    local target="${CS_TARGET_PANE:-}"
    if [[ -n "$target" ]]; then
        tmux send-keys -t "$target" "cd '$dir'" Enter
    elif [[ -n "${TMUX:-}" ]]; then
        tmux send-keys "cd '$dir'" Enter
    fi
}

# ── git helpers ───────────────────────────────────────────────────────────────

default_branch() {
    local repo="$1"
    local branch
    branch=$(git -C "$repo" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null \
        | sed 's|refs/remotes/origin/||') && [[ -n "$branch" ]] && echo "$branch" && return
    for b in devnet main master develop; do
        if git -C "$repo" show-ref --verify --quiet "refs/remotes/origin/$b" 2>/dev/null \
        || git -C "$repo" show-ref --verify --quiet "refs/heads/$b" 2>/dev/null; then
            echo "$b"; return
        fi
    done
    die "cannot determine default branch for $repo"
}

find_repo() {
    local project="$1"
    local path="$CS_PROJECTS/$project"
    [[ -d "$path" ]] || die "project not found: $path"
    echo "$path"
}

ensure_tracking_branch() {
    local repo="$1" name="$2" upstream="$3"
    if ! git -C "$repo" show-ref --verify --quiet "refs/heads/$name" 2>/dev/null; then
        git -C "$repo" branch --track "$name" "$upstream" >/dev/null
    fi
    echo "$name"
}

# Ensure a research or review worktree exists, return its path.
_ensure_mode_worktree() {
    local project="$1" mode="$2"
    local wt_path="$CS_WORKTREES/$project/$mode"

    if [[ ! -d "$wt_path" ]]; then
        local repo_path
        repo_path=$(find_repo "$project")
        local db
        db=$(default_branch "$repo_path")
        mkdir -p "$CS_WORKTREES/$project"
        local branch
        branch=$(ensure_tracking_branch "$repo_path" "cs/$mode/$project" "origin/$db")
        git -C "$repo_path" worktree add "$wt_path" "$branch" >/dev/null
        echo "→ created $mode worktree for $project" >&2
    fi

    echo "$wt_path"
}

# ── commands ──────────────────────────────────────────────────────────────────

cmd_research() {
    local project="${1:-}"
    [[ -n "$project" ]] || project=$(ctx_project) || true
    [[ -n "$project" ]] || die "usage: cs research [project]  (can't detect project from CWD)"

    local wt_path
    wt_path=$(_ensure_mode_worktree "$project" research)

    _switch_to_mode research
    _cd_pane "$wt_path"
}

cmd_review() {
    local project branch

    case $# in
        0)
            project=$(ctx_project) || true
            [[ -n "$project" ]] || die "usage: cs review [project] [branch]"
            ;;
        1)
            # Could be a project or a branch — check if it's a known project
            if [[ -d "$CS_PROJECTS/$1" ]]; then
                project="$1"
            else
                project=$(ctx_project) || true
                [[ -n "$project" ]] || die "usage: cs review [project] [branch]"
                branch="$1"
            fi
            ;;
        2)  project="$1"; branch="$2" ;;
        *)  die "usage: cs review [project] [branch]" ;;
    esac

    local wt_path
    wt_path=$(_ensure_mode_worktree "$project" review)

    if [[ -n "${branch:-}" ]]; then
        git -C "$wt_path" fetch origin
        git -C "$wt_path" checkout "$branch" 2>/dev/null \
            || git -C "$wt_path" checkout -b "$branch" "origin/$branch"
        echo "→ review: $branch"
    fi

    _switch_to_mode review
    _cd_pane "$wt_path"
}

cmd_work() {
    local project branch

    case $# in
        1)  branch="$1"
            project=$(ctx_project) || true
            [[ -n "$project" ]] || die "usage: cs work [project] <branch>"
            ;;
        2)  project="$1"; branch="$2" ;;
        *)  die "usage: cs work [project] <branch>" ;;
    esac

    local repo_path
    repo_path=$(find_repo "$project")

    local slug
    slug=$(branch_slug "$branch")
    local wt_path="$CS_WORKTREES/$project/$slug"

    if [[ ! -d "$wt_path" ]]; then
        mkdir -p "$CS_WORKTREES/$project"
        if git -C "$repo_path" show-ref --verify --quiet "refs/remotes/origin/$branch" 2>/dev/null; then
            git -C "$repo_path" worktree add -b "$branch" "$wt_path" "origin/$branch" >/dev/null
        elif git -C "$repo_path" show-ref --verify --quiet "refs/heads/$branch" 2>/dev/null; then
            git -C "$repo_path" worktree add "$wt_path" "$branch" >/dev/null
        else
            local db
            db=$(default_branch "$repo_path")
            echo "→ branch '$branch' not found, creating from origin/$db"
            git -C "$repo_path" worktree add -b "$branch" "$wt_path" "origin/$db" >/dev/null
        fi
        echo "→ created worktree: $project/$slug"
    fi

    _switch_to_mode work
    _cd_pane "$wt_path"
}

cmd_done() {
    local project branch

    case $# in
        0)
            local entries=()
            if [[ -d "$CS_WORKTREES" ]]; then
                while IFS= read -r proj_dir; do
                    local proj
                    proj=$(basename "$proj_dir")
                    while IFS= read -r tree_dir; do
                        [[ -d "$tree_dir" ]] || continue
                        local tree
                        tree=$(basename "$tree_dir")
                        [[ "$tree" == "research" || "$tree" == "review" ]] && continue
                        entries+=("$proj/$tree")
                    done < <(find "$proj_dir" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort)
                done < <(find "$CS_WORKTREES" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort)
            fi
            [[ ${#entries[@]} -gt 0 ]] || die "no work trees found"
            local selected
            selected=$(printf '%s\n' "${entries[@]}" | \
                fzf --height 40% --reverse --border \
                    --header "select work tree to remove:")
            [[ -n "$selected" ]] || return 0
            project="${selected%%/*}"
            branch="${selected#*/}"
            ;;
        1)  branch="$1"
            project=$(ctx_project) || true
            [[ -n "$project" ]] || die "usage: cs done [project] <branch>"
            ;;
        2)  project="$1"; branch="$2" ;;
        *)  die "usage: cs done [project] [branch]" ;;
    esac

    local slug
    slug=$(branch_slug "$branch")

    local wt_path="$CS_WORKTREES/$project/$branch"
    [[ -d "$wt_path" ]] || wt_path="$CS_WORKTREES/$project/$slug"
    [[ -d "$wt_path" ]] || die "worktree not found for $project/$branch"

    local repo_path
    repo_path=$(find_repo "$project")

    git -C "$repo_path" worktree remove "$wt_path" --force
    echo "→ removed worktree: $project/$(basename "$wt_path")"
}

cmd_go() {
    local mode="${1:-${CS_MODE:-}}"

    if [[ -z "$mode" ]]; then
        mode=$(_current_mode)
    fi

    [[ -n "$mode" ]] || die "not in a cs window — specify mode: research|review|work"

    local current
    current=$(_current_mode) || true
    if [[ "$mode" != "${current:-}" ]]; then
        _switch_to_mode "$mode"
    fi

    _pick "$mode"
}

_pick() {
    local mode="$1"

    [[ -d "$CS_WORKTREES" ]] || die "no worktrees found"

    # Step 1: pick a project (from ~/projects, deduplicated with worktrees)
    local projects
    projects=$(
        {
            if [[ -d "$CS_PROJECTS" ]]; then
                find "$CS_PROJECTS" -mindepth 1 -maxdepth 1 -type d -exec test -d {}/.git \; -print 2>/dev/null \
                    | xargs -I{} basename {}
            fi
            if [[ -d "$CS_WORKTREES" ]]; then
                find "$CS_WORKTREES" -mindepth 1 -maxdepth 1 -type d 2>/dev/null \
                    | xargs -I{} basename {}
            fi
        } | sort -u
    )

    [[ -n "$projects" ]] || die "no projects found"

    local project
    project=$(echo "$projects" | \
        fzf --reverse --border \
            --header "[$mode] select project:")
    [[ -n "$project" ]] || return 0

    local wt_path

    case "$mode" in
        research|review)
            # Lazily create worktree if needed
            wt_path=$(_ensure_mode_worktree "$project" "$mode")
            ;;
        work)
            # Step 2: pick a work worktree within the project
            local trees=()
            while IFS= read -r tree_dir; do
                [[ -d "$tree_dir" ]] || continue
                local tree
                tree=$(basename "$tree_dir")
                [[ "$tree" == "research" || "$tree" == "review" ]] && continue
                trees+=("$tree")
            done < <(find "$CS_WORKTREES/$project" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort)

            [[ ${#trees[@]} -gt 0 ]] || die "no work worktrees for '$project'"

            local selected
            selected=$(printf '%s\n' "${trees[@]}" | \
                fzf --reverse --border \
                    --header "[$mode → $project] select worktree:")
            [[ -n "$selected" ]] || return 0

            wt_path="$CS_WORKTREES/$project/$selected"
            ;;
    esac

    local target="${CS_TARGET_PANE:-}"
    if [[ -n "$target" ]]; then
        tmux send-keys -t "$target" "cd '$wt_path'" Enter
    elif [[ -n "${TMUX:-}" ]]; then
        tmux send-keys "cd '$wt_path'" Enter
    else
        echo "$wt_path"
    fi
}

cmd_help() {
    cat <<'EOF'
cs — context-switch

Model: single session, three fixed mode windows, scoped worktree picker

Commands:
  cs research [project]           switch to research mode for project
  cs review [project] [branch]    switch to review mode (optionally checkout branch)
  cs work [project] <branch>      switch to work mode for a feature branch
  cs done [project] [branch]      remove a work worktree
  cs go [mode]                    scoped worktree picker (bound to Alt+p)

Each command creates the worktree on first use — no init step needed.
Project is auto-detected from CWD when omitted.

Navigation:
  Alt+i / Alt+o                   previous / next mode window
  Alt+p                           project picker (scoped to current mode)

Modes: research | review | work

Worktrees:  $CS_WORKTREES_DIR  (default: ~/worktrees)
Projects:   $CS_PROJECTS_DIR   (default: ~/projects)
Session:    $CS_SESSION         (default: main)
EOF
}

case "${1:-}" in
    research)       shift; cmd_research "$@" ;;
    review)         shift; cmd_review   "$@" ;;
    work)           shift; cmd_work     "$@" ;;
    done)           shift; cmd_done     "$@" ;;
    go)             shift; cmd_go       "$@" ;;
    help|--help|-h) cmd_help ;;
    *) printf 'cs: unknown command: %s\n\n' "${1:-}" >&2; cmd_help; exit 1 ;;
esac
