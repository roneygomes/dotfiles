#!/usr/bin/env bash
# devbox - manage the dev container
#
# Commands:
#   devbox build   Build the image from the dotfiles repo
#   devbox start   Create (or resume) the container and attach a shell

set -e

IMAGE="${DEVBOX_IMAGE:-devbox}"
CONTAINER="${DEVBOX_CONTAINER:-devbox}"
DOTFILES_DIR="${DOTFILES_DIR:-$HOME/projects/dotfiles}"

# Port used to bridge the macOS SSH agent socket into the container via TCP.
SSH_BRIDGE_PORT="${DEVBOX_SSH_BRIDGE_PORT:-12345}"
BRIDGE_STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/devbox"
SSH_BRIDGE_PID_FILE="$BRIDGE_STATE_DIR/ssh-bridge.pid"
SSH_BRIDGE_SOCK_FILE="$BRIDGE_STATE_DIR/ssh-bridge.sock"

# Port used to bridge the 1Password daemon socket into the container via TCP.
OP_BRIDGE_PORT="${DEVBOX_OP_BRIDGE_PORT:-12346}"
OP_BRIDGE_PID_FILE="$BRIDGE_STATE_DIR/op-bridge.pid"
OP_BRIDGE_SOCK_FILE="$BRIDGE_STATE_DIR/op-bridge.sock"
OP_DAEMON_SOCK="$HOME/.config/op/op-daemon.sock"

# ---------------------------------------------------------------------------
# SSH agent bridge
#
# macOS Unix sockets can't be used directly inside OrbStack/Docker containers
# (virtio-fs shares the file but not the socket endpoint). Instead we run a
# socat TCP listener on the Mac that forwards to $SSH_AUTH_SOCK, and a
# corresponding socat inside the container that exposes it as a Unix socket.
# ---------------------------------------------------------------------------
# Start a socat TCP bridge for a Unix socket.
# Usage: _ensure_bridge <socket_path> <tcp_port> <pid_file> <sock_file> <label>
_ensure_bridge() {
  local socket="$1" port="$2" pid_file="$3" sock_file="$4" label="$5"

  [[ -S "$socket" ]] || return 0
  command -v socat &>/dev/null || { echo "warning: socat not found, $label forwarding disabled" >&2; return 0; }

  mkdir -p "$BRIDGE_STATE_DIR"

  if [[ -f "$pid_file" && -f "$sock_file" ]]; then
    local pid; pid=$(cat "$pid_file")
    local last_sock; last_sock=$(cat "$sock_file")
    if kill -0 "$pid" 2>/dev/null && [[ "$last_sock" == "$socket" ]]; then
      return 0
    fi
    kill "$pid" 2>/dev/null || true
  fi

  socat "TCP-LISTEN:${port},fork,reuseaddr" \
        "UNIX-CONNECT:${socket}" &
  echo $! > "$pid_file"
  echo "$socket" > "$sock_file"
}

ensure_ssh_bridge() {
  _ensure_bridge "${SSH_AUTH_SOCK:-}" "$SSH_BRIDGE_PORT" \
    "$SSH_BRIDGE_PID_FILE" "$SSH_BRIDGE_SOCK_FILE" "SSH agent"
}

ensure_op_bridge() {
  _ensure_bridge "$OP_DAEMON_SOCK" "$OP_BRIDGE_PORT" \
    "$OP_BRIDGE_PID_FILE" "$OP_BRIDGE_SOCK_FILE" "1Password daemon"
}

# Export Claude Code OAuth credentials from the macOS Keychain into the
# plaintext fallback file that Claude Code uses on Linux (~/.claude/.credentials.json).
sync_claude_credentials() {
  local cred_file="$HOME/.claude/.credentials.json"
  local creds
  creds=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null) || return 0
  [[ -n "$creds" ]] || return 0

  printf '%s' "$creds" > "$cred_file"
  chmod 600 "$cred_file"
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------
cmd_build() {
  if [[ ! -f "$DOTFILES_DIR/Dockerfile" ]]; then
    echo "error: Dockerfile not found in $DOTFILES_DIR" >&2
    echo "       Set DOTFILES_DIR to override the default location." >&2
    exit 1
  fi

  echo "Building image '$IMAGE' from $DOTFILES_DIR ..."
  docker build \
    --build-arg "USERNAME=$USER" \
    --build-arg "USER_HOME=$HOME" \
    -t "$IMAGE" "$DOTFILES_DIR"
  echo "Done."
}

cmd_start() {
  local status
  if docker inspect --type container "$CONTAINER" &>/dev/null; then
    status=$(docker inspect --type container --format='{{.State.Status}}' "$CONTAINER")
  else
    status="missing"
  fi

  case "$status" in
    running)
      echo "Attaching to running container '$CONTAINER' ..."
      exec docker exec -it "$CONTAINER" /bin/zsh
      ;;
    exited|created|paused)
      ensure_ssh_bridge
      ensure_op_bridge
      sync_claude_credentials
      echo "Starting container '$CONTAINER' ..."
      exec docker start -ai "$CONTAINER"
      ;;
    missing)
      ensure_ssh_bridge
      ensure_op_bridge
      sync_claude_credentials
      echo "Creating container '$CONTAINER' from image '$IMAGE' ..."
      exec docker run -it \
        --name "$CONTAINER" \
        --add-host=host.docker.internal:host-gateway \
        -e "SSH_AGENT_BRIDGE_PORT=${SSH_BRIDGE_PORT}" \
        -e "OP_AGENT_BRIDGE_PORT=${OP_BRIDGE_PORT}" \
        -e "HOME=$HOME" \
        -v "${CONTAINER}_home:$HOME" \
        -v /var/run/docker.sock:/var/run/docker.sock \
        -v "$HOME/projects:$HOME/projects" \
        -v "$HOME/.claude:$HOME/.claude" \
        -v "$HOME/.claude.json:$HOME/.claude.json" \
        -v "$HOME/.ssh:$HOME/.ssh-host:ro" \
        -v "$DOTFILES_DIR/docker/.zshrc:$HOME/.zshrc:ro" \
        -v "$DOTFILES_DIR/docker/.zshenv:$HOME/.zshenv:ro" \
        -v "$DOTFILES_DIR/.p10k.zsh:$HOME/.p10k.zsh:ro" \
        -v "$DOTFILES_DIR/.config/git:$HOME/.config/git:ro" \
        -v "$DOTFILES_DIR/.local/bin:$HOME/.local/bin:ro" \
        "$IMAGE"
      ;;
    *)
      echo "error: container '$CONTAINER' is in unexpected state: $status" >&2
      exit 1
      ;;
  esac
}

cmd_help() {
  cat << EOF
devbox - manage the dev container

Usage:
  devbox build   Build the Docker image
  devbox start   Attach to the container (creates it if needed)
  devbox help    Show this help message

Environment variables:
  DEVBOX_IMAGE            Image name (default: devbox)
  DEVBOX_CONTAINER        Container name (default: devbox)
  DOTFILES_DIR            Path to dotfiles repo (default: ~/projects/dotfiles)
  DEVBOX_SSH_BRIDGE_PORT  TCP port for SSH agent bridge (default: 12345)
  DEVBOX_OP_BRIDGE_PORT   TCP port for 1Password daemon bridge (default: 12346)
EOF
}

# ---------------------------------------------------------------------------
# Router
# ---------------------------------------------------------------------------
case "${1:-}" in
  build) cmd_build ;;
  start) cmd_start ;;
  help|--help|-h) cmd_help ;;
  "")
    echo "error: command required" >&2
    echo "" >&2
    cmd_help >&2
    exit 1
    ;;
  *)
    echo "error: unknown command '$1'" >&2
    echo "" >&2
    cmd_help >&2
    exit 1
    ;;
esac
