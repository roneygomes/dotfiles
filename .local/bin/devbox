#!/usr/bin/env bash
# devbox - manage per-directory dev containers
#
# Commands:
#   devbox build          Build the image from the dotfiles repo
#   devbox start [path]   Create (or resume) a container scoped to path (default: $PWD)
#   devbox stop  [path]   Stop the container for path (default: $PWD)
#   devbox rm             Remove all stopped containers and their volumes
#   devbox list           List all devbox containers

set -e

IMAGE="${DEVBOX_IMAGE:-devbox}"
DOTFILES_DIR="${DOTFILES_DIR:-$HOME/projects/dotfiles}"

# Port used to bridge the macOS SSH agent socket into the container via TCP.
SSH_BRIDGE_PORT="${DEVBOX_SSH_BRIDGE_PORT:-12345}"
BRIDGE_STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/devbox"
SSH_BRIDGE_PID_FILE="$BRIDGE_STATE_DIR/ssh-bridge.pid"
SSH_BRIDGE_SOCK_FILE="$BRIDGE_STATE_DIR/ssh-bridge.sock"

# Port used to bridge the 1Password daemon socket into the container via TCP.
OP_BRIDGE_PORT="${DEVBOX_OP_BRIDGE_PORT:-12346}"
OP_BRIDGE_PID_FILE="$BRIDGE_STATE_DIR/op-bridge.pid"
OP_BRIDGE_SOCK_FILE="$BRIDGE_STATE_DIR/op-bridge.sock"
OP_DAEMON_SOCK="$HOME/.config/op/op-daemon.sock"

# ---------------------------------------------------------------------------
# SSH agent bridge
#
# macOS Unix sockets can't be used directly inside OrbStack/Docker containers
# (virtio-fs shares the file but not the socket endpoint). Instead we run a
# socat TCP listener on the Mac that forwards to $SSH_AUTH_SOCK, and a
# corresponding socat inside the container that exposes it as a Unix socket.
# ---------------------------------------------------------------------------
# Start a socat TCP bridge for a Unix socket.
# Usage: _ensure_bridge <socket_path> <tcp_port> <pid_file> <sock_file> <label>
_ensure_bridge() {
  local socket="$1" port="$2" pid_file="$3" sock_file="$4" label="$5"

  [[ -S "$socket" ]] || return 0
  command -v socat &>/dev/null || { echo "warning: socat not found, $label forwarding disabled" >&2; return 0; }

  mkdir -p "$BRIDGE_STATE_DIR"

  if [[ -f "$pid_file" && -f "$sock_file" ]]; then
    local pid; pid=$(cat "$pid_file")
    local last_sock; last_sock=$(cat "$sock_file")
    if kill -0 "$pid" 2>/dev/null && [[ "$last_sock" == "$socket" ]]; then
      return 0
    fi
    kill "$pid" 2>/dev/null || true
  fi

  socat "TCP-LISTEN:${port},fork,reuseaddr" \
        "UNIX-CONNECT:${socket}" &
  echo $! > "$pid_file"
  echo "$socket" > "$sock_file"
}

ensure_ssh_bridge() {
  _ensure_bridge "${SSH_AUTH_SOCK:-}" "$SSH_BRIDGE_PORT" \
    "$SSH_BRIDGE_PID_FILE" "$SSH_BRIDGE_SOCK_FILE" "SSH agent"
}

ensure_op_bridge() {
  _ensure_bridge "$OP_DAEMON_SOCK" "$OP_BRIDGE_PORT" \
    "$OP_BRIDGE_PID_FILE" "$OP_BRIDGE_SOCK_FILE" "1Password daemon"
}

# Export Claude Code OAuth credentials from the macOS Keychain into the
# plaintext fallback file that Claude Code uses on Linux (~/.claude/.credentials.json).
sync_claude_credentials() {
  local cred_file="$HOME/.claude/.credentials.json"
  local creds
  creds=$(security find-generic-password -s "Claude Code-credentials" -w 2>/dev/null) || return 0
  [[ -n "$creds" ]] || return 0

  printf '%s' "$creds" > "$cred_file"
  chmod 600 "$cred_file"
}

# Export the GitHub CLI OAuth token from the macOS Keychain into a file
# that the container entrypoint sources as GH_TOKEN.
sync_gh_credentials() {
  local token_file="$HOME/.config/gh/.devbox-token"
  mkdir -p "$(dirname "$token_file")"

  local raw
  raw=$(security find-generic-password -s "gh:github.com" -w 2>/dev/null) || { touch "$token_file"; return 0; }
  [[ -n "$raw" ]] || { touch "$token_file"; return 0; }

  # go-keyring stores the value as base64 with a prefix
  local token
  if [[ "$raw" == go-keyring-base64:* ]]; then
    token=$(printf '%s' "${raw#go-keyring-base64:}" | base64 -d)
  else
    token="$raw"
  fi

  printf '%s' "$token" > "$token_file"
  chmod 600 "$token_file"
}

# ---------------------------------------------------------------------------
# Container naming
# ---------------------------------------------------------------------------
# Derive a unique container name from an absolute directory path.
# Format: devbox-<sanitized-basename>-<8-char-hash>
_container_name_from_path() {
  local abs_path="$1"
  local base
  base=$(basename "$abs_path")
  # Lowercase, replace non-alphanumeric with hyphens, collapse runs, strip edges
  base=$(printf '%s' "$base" | tr '[:upper:]' '[:lower:]' | tr -cs '[:alnum:]' '-' | sed 's/^-//;s/-$//')
  local hash
  hash=$(printf '%s' "$abs_path" | shasum -a 256 | cut -c1-8)
  printf 'devbox-%s-%s' "$base" "$hash"
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------
cmd_build() {
  if [[ ! -f "$DOTFILES_DIR/Dockerfile" ]]; then
    echo "error: Dockerfile not found in $DOTFILES_DIR" >&2
    echo "       Set DOTFILES_DIR to override the default location." >&2
    exit 1
  fi

  echo "Building image '$IMAGE' from $DOTFILES_DIR ..."
  docker build \
    --build-arg "USERNAME=$USER" \
    --build-arg "USER_HOME=$HOME" \
    -t "$IMAGE" "$DOTFILES_DIR"
  echo "Done."
}

cmd_start() {
  local target_dir
  target_dir="$(realpath "${1:-.}")"

  if [[ ! -d "$target_dir" ]]; then
    echo "error: not a directory: $target_dir" >&2
    exit 1
  fi

  local container volume
  container="$(_container_name_from_path "$target_dir")"
  volume="${container}_home"

  local status
  if docker inspect --type container "$container" &>/dev/null; then
    status=$(docker inspect --type container --format='{{.State.Status}}' "$container")
  else
    status="missing"
  fi

  case "$status" in
    running)
      echo "Attaching to running container '$container' ($target_dir) ..."
      exec docker exec -it \
        -e "LC_TERMINAL=${LC_TERMINAL:-}" \
        -e "TERM_PROGRAM=${TERM_PROGRAM:-}" \
        -w "$target_dir" "$container" /bin/zsh
      ;;
    exited|created|paused)
      ensure_ssh_bridge
      ensure_op_bridge
      sync_claude_credentials
      sync_gh_credentials
      echo "Starting container '$container' ($target_dir) ..."
      exec docker start -ai "$container"
      ;;
    missing)
      ensure_ssh_bridge
      ensure_op_bridge
      sync_claude_credentials
      sync_gh_credentials
      echo "Creating container '$container' for $target_dir ..."
      exec docker run -it \
        --name "$container" \
        --label "devbox.project.dir=$target_dir" \
        --add-host=host.docker.internal:host-gateway \
        -e "SSH_AGENT_BRIDGE_PORT=${SSH_BRIDGE_PORT}" \
        -e "OP_AGENT_BRIDGE_PORT=${OP_BRIDGE_PORT}" \
        -e "HOME=$HOME" \
        -e "LC_TERMINAL=${LC_TERMINAL:-}" \
        -e "TERM_PROGRAM=${TERM_PROGRAM:-}" \
        -v "${volume}:$HOME" \
        -v /var/run/docker.sock:/var/run/docker.sock \
        -v "$target_dir:$target_dir" \
        -v "$HOME/.claude:$HOME/.claude" \
        -v "$HOME/.claude.json:$HOME/.claude.json" \
        -v "$HOME/.config/gh/.devbox-token:$HOME/.config/gh/.devbox-token:ro" \
        -v "$HOME/.ssh:$HOME/.ssh-host:ro" \
        -v "$DOTFILES_DIR/docker/.zshrc:$HOME/.zshrc:ro" \
        -v "$DOTFILES_DIR/docker/.zshenv:$HOME/.zshenv:ro" \
        -v "$DOTFILES_DIR/.p10k.zsh:$HOME/.p10k.zsh:ro" \
        -v "$DOTFILES_DIR/.config/git:$HOME/.config/git:ro" \
        -v "$DOTFILES_DIR/.local/bin:$HOME/.local/bin:ro" \
        -w "$target_dir" \
        "$IMAGE"
      ;;
    *)
      echo "error: container '$container' is in unexpected state: $status" >&2
      exit 1
      ;;
  esac
}

cmd_stop() {
  local target_dir
  target_dir="$(realpath "${1:-.}")"

  if [[ ! -d "$target_dir" ]]; then
    echo "error: not a directory: $target_dir" >&2
    exit 1
  fi

  local container
  container="$(_container_name_from_path "$target_dir")"

  if docker inspect --type container "$container" &>/dev/null; then
    echo "Stopping container '$container' ($target_dir) ..."
    docker stop "$container"
  else
    echo "No devbox container found for $target_dir" >&2
    exit 1
  fi
}

cmd_list() {
  printf "%-40s %-20s %s\n" "CONTAINER" "STATUS" "PROJECT"
  docker ps -a --filter "name=^devbox-" --format '{{.Names}}\t{{.Status}}\t{{.Label "devbox.project.dir"}}' \
    | while IFS=$'\t' read -r name status dir; do
        printf "%-40s %-20s %s\n" "$name" "$status" "$dir"
      done
}

cmd_rm() {
  local containers
  containers=$(docker ps -a --filter "name=^devbox-" --filter "status=exited" --filter "status=created" \
    --format '{{.Names}}\t{{.Label "devbox.project.dir"}}')

  if [[ -z "$containers" ]]; then
    echo "No stopped devbox containers to remove."
    return 0
  fi

  echo "Stopped devbox containers:"
  while IFS=$'\t' read -r name dir; do
    printf "  %-40s %s\n" "$name" "$dir"
  done <<< "$containers"
  echo ""

  printf "Remove these containers and their home volumes? [y/N] "
  read -r confirm
  [[ "$confirm" == [yY] ]] || { echo "Aborted."; return 0; }

  while IFS=$'\t' read -r name _; do
    local volume="${name}_home"
    echo "Removing container '$name' ..."
    docker rm "$name"
    if docker volume inspect "$volume" &>/dev/null; then
      echo "Removing volume '$volume' ..."
      docker volume rm "$volume"
    fi
  done <<< "$containers"
  echo "Done."
}

cmd_help() {
  cat << EOF
devbox - manage per-directory dev containers

Usage:
  devbox build          Build the Docker image
  devbox start [path]   Attach to the container for path (default: current directory)
  devbox stop  [path]   Stop the container for path (default: current directory)
  devbox rm             Remove all stopped containers and their home volumes
  devbox list           List all devbox containers
  devbox help           Show this help message

Environment variables:
  DEVBOX_IMAGE            Image name (default: devbox)
  DOTFILES_DIR            Path to dotfiles repo (default: ~/projects/dotfiles)
  DEVBOX_SSH_BRIDGE_PORT  TCP port for SSH agent bridge (default: 12345)
  DEVBOX_OP_BRIDGE_PORT   TCP port for 1Password daemon bridge (default: 12346)
EOF
}

# ---------------------------------------------------------------------------
# Router
# ---------------------------------------------------------------------------
case "${1:-}" in
  build) shift; cmd_build "$@" ;;
  start) shift; cmd_start "$@" ;;
  stop)  shift; cmd_stop "$@" ;;
  rm)    shift; cmd_rm "$@" ;;
  list)  shift; cmd_list "$@" ;;
  help|--help|-h) cmd_help ;;
  "")
    echo "error: command required" >&2
    echo "" >&2
    cmd_help >&2
    exit 1
    ;;
  *)
    echo "error: unknown command '$1'" >&2
    echo "" >&2
    cmd_help >&2
    exit 1
    ;;
esac
