#!/usr/bin/env bash
# tmux-picker: window picker (select existing or create new)
set -euo pipefail

windows=$(tmux list-windows -F '#{window_name}')

fzf_output=$(echo "$windows" | fzf \
    --reverse \
    --border \
    --no-sort \
    --print-query \
    --header 'Select or type new window name:') || true

query=$(echo "$fzf_output" | sed -n '1p')
selected=$(echo "$fzf_output" | sed -n '2p')

if [[ -n "$selected" ]]; then
    # Matched an existing window — switch to it
    target=$(tmux list-windows -F '#{window_index}|#{window_name}' | while IFS='|' read -r idx name; do
        [[ "$name" == "$selected" ]] && echo "$idx" && break
    done)
    [[ -n "$target" ]] && tmux select-window -t "$target"
elif [[ -n "$query" ]]; then
    # No match — create new window with that name
    tmux new-window -n "$query"
fi
