#!/usr/bin/env bash
# tmux-picker: window picker
set -euo pipefail

current=$(tmux display-message -p '#{window_name}')

items=()

while IFS= read -r name; do
  if [[ "$name" == "$current" ]]; then
    items+=("● $name")
  else
    items+=("  $name")
  fi
done < <(tmux list-windows -F '#{window_name}')

selected=$(printf '%s\n' "${items[@]}" | fzf --reverse --border=rounded --no-sort)
[[ -n "$selected" ]] || exit 0

# Strip marker
selected="${selected#● }"
selected="${selected#  }"

# Find window index by name and switch
target=$(tmux list-windows -F '#{window_index}|#{window_name}' | while IFS='|' read -r idx name; do
  [[ "$name" == "$selected" ]] && echo "$idx" && break
done)
[[ -n "$target" ]] && tmux select-window -t "$target"
