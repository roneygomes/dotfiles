# Path to your oh-my-zsh configuration.
ZSH=$HOME/.oh-my-zsh
ZSH_THEME="lambda"

plugins=(git git git-extras)

PATH=$PATH:~/bin
PATH=$PATH:~/.cargo/bin

PROJECTS_DIR=$HOME/code/projects

source $ZSH/oh-my-zsh.sh
source $PROJECTS_DIR/dotfiles/zsh/java.sh
source $PROJECTS_DIR/dotfiles/zsh/system.sh
source $PROJECTS_DIR/dotfiles/zsh/android.sh

[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
