{
    "workbench.colorTheme": "One Dark Pro Bold",
    "workbench.fontAliasing": "auto",
    "workbench.editor.showTabs": false,
    "workbench.list.keyboardNavigation": "simple",
    "workbench.sideBar.location": "right",
    "workbench.colorCustomizations": {
        "[One Dark Pro Bold]": {
            "sideBar.background": "#171A1E",
            "editor.background": "#171A1E",
            "editorCursor.foreground": "#C7C7C7",
            "editorCursor.background": "#000000"
        }
    },

    "editor.fontSize": 16,
    "editor.fontFamily": "Inconsolata, 'Fira Code', Menlo, Monaco, 'Courier New', monospace",
    "editor.minimap.enabled": false,
    "editor.renderWhitespace": "boundary",
    "editor.codeLens": false,
    "editor.lineNumbers": "relative",
    "[markdown]": {
        "editor.wordWrap": "on",
        "editor.wordWrapColumn": 80,
        "editor.quickSuggestions": false
    },

    "explorer.openEditors.visible": 0,
    "explorer.confirmDragAndDrop": false,

    "extensions.ignoreRecommendations": true,
    "files.trimTrailingWhitespace": true,

    "terraform.format": {
        "ignoreExtensionsOnSave": [
            ".tfsmurf",
            ".tf"
        ]
    },

    "gitlens.currentLine.enabled": false,

    "vim.camelCaseMotion.enable": true,
    "vim.foldfix": true,
    "vim.substituteGlobalFlag": true,

    "terminal.integrated.fontSize": 16,

    "projectManager.git.baseFolders": [
        "/Users/laroney/code/projects/work",
        "/Users/laroney/code/projects/personal",
        "/Users/laroney/code/projects/misc"
    ],
    "projectManager.sortList": "Recent",
    "projectManager.git.maxDepthRecursion": 1,
    "window.zoomLevel": 0,
    "files.exclude": {
        "**/__pycache__": true,
        "**/*.egg-info": true
    },
    "workbench.iconTheme": "vscode-icons"
}