# Default stow ignores (must be re-declared when using .stow-local-ignore)
RCS
.+,v
CVS
\.\#.+
\.cvsignore
\.svn
_darcs
\.hg
\.git
\.gitignore
\.gitmodules
\.stow-local-ignore

# Project-specific files (not meant for $HOME)
AGENTS\.md
CLAUDE\.md
\.claude/settings\.local\.json
LICENSE\.txt
README\.md

# App data / runtime state — lives under $HOME, not stowed from the repo.

# .config/ — top-level app data dirs
\.config/gcloud
\.config/htop
\.config/op
\.config/packer
\.config/raycast
\.config/yarn

